# ==========================================
# Bill Blue Environment Variables Example
# ==========================================

# Production Deployment Configuration
# Copy this file to a new file named '.env' and fill out the details.
# DO NOT commit '.env' (with real keys) to public Git repositories!

# Application basic parameters
PORT=3000
NODE_ENV=production

# Firebase Credentials Blueprint (Optional - Build-time Config)
# These correspond to the keys in your Firebase Web App configuration.
FIREBASE_API_KEY=AIzaSyA1...
FIREBASE_AUTH_DOMAIN=bill-blue.firebaseapp.com
FIREBASE_PROJECT_ID=bill-blue
FIREBASE_STORAGE_BUCKET=bill-blue.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-ABCDEF1234
